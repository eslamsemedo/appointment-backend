MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=appointment_dev
JWT_SECRET=change-me-to-a-secret-at-least-32-chars
PORT=3001
# Email is now per-tenant: each tenant configures their own sender (email +
# app password) at creation or in Settings. The three GMAIL_* vars below are an
# OPTIONAL shared fallback, used only for tenants with no sender of their own.
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM=your@gmail.com
# Comma-separated list of allowed origins, e.g. http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000
