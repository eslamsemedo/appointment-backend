MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=appointment_dev
JWT_SECRET=change-me-to-a-secret-at-least-32-chars
PORT=3001
# Outbound email is sent via Resend's HTTPS API (Railway blocks outbound SMTP).
# 1. Create a Resend account and an API key: https://resend.com
# 2. Verify a sending domain, then set EMAIL_FROM to an address on that domain.
# Each tenant's own address is used as the Reply-To automatically.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=appointments@yourdomain.com
# Comma-separated list of allowed origins, e.g. http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000
